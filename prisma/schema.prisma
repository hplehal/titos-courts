generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── LEAGUE SYSTEM ───

model League {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  dayOfWeek       String
  description     String?
  registrationFee Int
  maxTeams        Int
  tiersPerSlot    Int
  teamsPerTier    Int      @default(3)
  isActive        Boolean  @default(true)
  seasons         Season[]
  createdAt       DateTime @default(now())

  @@index([isActive])
}

model Season {
  id           String   @id @default(cuid())
  leagueId     String
  league       League   @relation(fields: [leagueId], references: [id])
  name         String
  seasonNumber Int
  startDate    DateTime
  endDate      DateTime
  totalWeeks   Int      @default(11)
  playoffWeeks Int      @default(1)
  status       String   @default("registration")
  teams        Team[]
  tiers        Tier[]
  weeks        Week[]
  createdAt    DateTime @default(now())

  @@index([leagueId, status, seasonNumber])
}

model Team {
  id             String          @id @default(cuid())
  name           String
  slug           String
  seasonId       String
  season         Season          @relation(fields: [seasonId], references: [id])
  captainName    String
  captainEmail   String
  captainPhone   String?
  players        Player[]
  tierPlacements TierPlacement[]
  homeMatches    Match[]         @relation("HomeTeam")
  awayMatches    Match[]         @relation("AwayTeam")
  refMatches     Match[]         @relation("RefTeam")
  wonMatches     Match[]         @relation("MatchWinner")
  createdAt      DateTime        @default(now())

  @@unique([seasonId, slug])
}

model Player {
  id           String       @id @default(cuid())
  name         String
  teamId       String
  team         Team         @relation(fields: [teamId], references: [id])
  jerseyNumber Int?
  waiverSigned Boolean      @default(false)
  stats        PlayerStat[]

  @@index([teamId])
}

model Tier {
  id          String          @id @default(cuid())
  seasonId    String
  season      Season          @relation(fields: [seasonId], references: [id])
  tierNumber  Int
  courtNumber Int
  timeSlot    String
  placements  TierPlacement[]

  @@unique([seasonId, tierNumber])
}

model TierPlacement {
  id             String  @id @default(cuid())
  tierId         String
  tier           Tier    @relation(fields: [tierId], references: [id])
  teamId         String
  team           Team    @relation(fields: [teamId], references: [id])
  weekId         String
  week           Week    @relation(fields: [weekId], references: [id])
  finishPosition Int?
  movement       String?

  @@unique([teamId, weekId])
  @@index([weekId])
  @@index([tierId])
}

model Week {
  id             String          @id @default(cuid())
  seasonId       String
  season         Season          @relation(fields: [seasonId], references: [id])
  weekNumber     Int
  date           DateTime
  isPlayoff      Boolean         @default(false)
  status         String          @default("upcoming")
  matches        Match[]
  tierPlacements TierPlacement[]
  playerStats    PlayerStat[]

  @@unique([seasonId, weekNumber])
  @@index([seasonId, status])
}

model Match {
  id          String       @id @default(cuid())
  weekId      String
  week        Week         @relation(fields: [weekId], references: [id])
  // homeTeamId / awayTeamId are nullable so playoff bracket shells can be
  // created before their teams are known (SF and Final feeders wait for
  // upstream QFs to finalize). Regular-season seeder still always sets
  // both — null here means "team to be determined."
  homeTeamId  String?
  homeTeam    Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  String?
  awayTeam    Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  refTeamId   String?
  refTeam     Team?        @relation("RefTeam", fields: [refTeamId], references: [id])
  // Display labels for empty slots, e.g. '1 Seed' / 'W QF1'. Rendered when
  // the corresponding team is still null. Set by the playoff generator.
  homeSeedLabel String?
  awaySeedLabel String?
  // Winner team — set when status flips to FINAL. Drives advancement.
  winnerId    String?
  winnerTeam  Team?        @relation("MatchWinner", fields: [winnerId], references: [id])
  courtNumber Int
  // Per-match start time. Used by playoff matches where the QFs run
  // sequentially on one court (8 PM / 9 PM) and W11 has SFs at 8 / 9:30
  // and Final at 11 PM. Regular-season matches leave this null and
  // inherit the week's start time from the schedule defaults.
  scheduledTime DateTime?
  // tierNumber doubles as "division index" (1=Diamond, 2=Platinum,
  // 3=Gold, 4=Silver) for playoff matches. Keeps regular-season tier
  // semantics for non-playoff weeks.
  tierNumber  Int
  // roundNumber doubles as "playoff round" for playoff weeks
  // (1=QF, 2=SF, 3=Final). Regular-season meaning unchanged.
  roundNumber Int
  gameOrder   Int
  status      String       @default("scheduled")
  // Bracket advancement: winner of THIS match goes into nextMatch.
  // Populated when the playoff bracket is generated; null for regular
  // season matches. The empty slot (home vs away) is resolved by
  // advanceLeaguePlayoffWinner based on reseeding rules.
  nextMatchId String?
  nextMatch   Match?       @relation("MatchAdvance", fields: [nextMatchId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  feeders     Match[]      @relation("MatchAdvance")
  scores      SetScore[]
  playerStats PlayerStat[]
  createdAt   DateTime     @default(now())

  @@index([weekId, status])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([refTeamId])
  @@index([nextMatchId])
  @@index([weekId, tierNumber, gameOrder])
}

model SetScore {
  id        String @id @default(cuid())
  matchId   String
  match     Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber Int
  homeScore Int
  awayScore Int

  @@unique([matchId, setNumber])
}

// Per-week (and optionally per-match) player stats. `matchId` is nullable so
// we can record season-totals-style rows imported from the master sheet
// without splitting numbers across individual matches. The unique constraint
// is on (playerId, weekId) — one row per player per week — with matchId as
// optional extra context for future per-match tracking.
model PlayerStat {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id])
  matchId  String?
  match    Match?  @relation(fields: [matchId], references: [id])
  weekId   String?
  week     Week?   @relation(fields: [weekId], references: [id])
  kills    Int     @default(0)
  assists  Int     @default(0)
  digs     Int     @default(0)
  blocks   Int     @default(0)
  aces     Int     @default(0)
  errors   Int     @default(0)

  @@unique([playerId, weekId])
  @@index([matchId])
  @@index([weekId])
}

// ─── TOURNAMENT SYSTEM ───

model Tournament {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  date                 DateTime
  endDate              DateTime?
  venue                String?
  venueAddress         String?
  poolSize             Int?
  poolCount            Int?
  description          String?
  format               String?
  // bracketFormat: 'gold-silver' (legacy 4-pool double-bracket) or
  // 'crossover-single-elim' (May 23 style: 2-pool, top 3 + 1 play-in
  // winner per pool feeds an 8-team single-elim bracket with A↔B crossover).
  // Defaults to 'gold-silver' so existing tournaments keep their behaviour.
  bracketFormat        String             @default("gold-silver")
  // Per-match defaults applied when seeding the schedule:
  //   poolMatchFormat: 'pool-2set-25-cap-27' (default) | 'pool-1set-25-cap-27'
  //   bracketMatchFormat: 'bo3-25-15-cap-17' (default) | 'bo3-25-15-no-cap'
  poolMatchFormat      String             @default("pool-2set-25-cap-27")
  bracketMatchFormat   String             @default("bo3-25-15-cap-17")
  registrationFee      Int?
  maxTeams             Int?
  registrationDeadline DateTime?
  prizePool            Int?
  status               String             @default("registration")
  rules                String?            // Free-form markdown for the public Captain's Package page.
  pools                TournamentPool[]
  brackets             TournamentBracket[]
  tournamentTeams      TournamentTeam[]
  createdAt            DateTime           @default(now())
}

model TournamentTeam {
  id           String           @id @default(cuid())
  tournamentId String
  tournament   Tournament       @relation(fields: [tournamentId], references: [id])
  name         String
  captainName  String
  captainEmail String?
  captainPhone String?
  poolId       String?
  pool         TournamentPool?  @relation(fields: [poolId], references: [id])
  seed         Int?
  homeMatches  TournamentMatch[] @relation("TournHomeTeam")
  awayMatches  TournamentMatch[] @relation("TournAwayTeam")
  refMatches   TournamentMatch[] @relation("TournRefTeam")

  @@index([tournamentId])
  @@index([poolId])
}

model TournamentPool {
  id           String            @id @default(cuid())
  tournamentId String
  tournament   Tournament        @relation(fields: [tournamentId], references: [id])
  name         String
  teams        TournamentTeam[]
  matches      TournamentMatch[]

  @@index([tournamentId])
}

model TournamentBracket {
  id           String            @id @default(cuid())
  tournamentId String
  tournament   Tournament        @relation(fields: [tournamentId], references: [id])
  division     String
  matches      TournamentMatch[]

  @@index([tournamentId])
}

model TournamentMatch {
  id              String               @id @default(cuid())
  poolId          String?
  pool            TournamentPool?      @relation(fields: [poolId], references: [id])
  bracketId       String?
  bracket         TournamentBracket?   @relation(fields: [bracketId], references: [id])
  homeTeamId      String?
  homeTeam        TournamentTeam?      @relation("TournHomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId      String?
  awayTeam        TournamentTeam?      @relation("TournAwayTeam", fields: [awayTeamId], references: [id])
  homeSeedLabel   String?              // display label like "A1" before team resolves (bracket)
  awaySeedLabel   String?
  courtNumber     Int?
  scheduledTime   DateTime?
  refTeamId       String?              // team on the whistle — manual override. Pool matches fall back to the canonical PDF rotation (refRotation.js) when null.
  refTeam         TournamentTeam?      @relation("TournRefTeam", fields: [refTeamId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  // stage: 'pool' (default) | 'play-in' | 'bracket'. Lets the bracket
  // generator find pool-play standings without grabbing intermediate
  // play-in matches, and lets the score-entry UI render the right
  // number of sets per format.
  stage           String               @default("pool")
  // matchFormat: 'pool-2set-25-cap-27' | 'pool-1set-25-cap-27' |
  //   'bo3-25-15-cap-17' | 'bo3-25-15-no-cap'. Drives computeMatchStatus
  //   and the number of score rows in the entry form. Null = inherit from
  //   the tournament-level poolMatchFormat/bracketMatchFormat defaults.
  matchFormat     String?
  status          String               @default("scheduled")
  winnerId        String?              // TournamentTeam id once decided
  roundNumber     Int?                 // pool: round of round-robin; bracket: unused
  gameOrder       Int?                 // ordering within a round
  bracketRound    Int?                 // 1=QF, 2=SF, 3=F
  bracketPosition Int?                 // slot within bracket round
  nextMatchId     String?              // bracket: winner advances to this match
  nextMatch       TournamentMatch?     @relation("BracketAdvance", fields: [nextMatchId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  feederMatches   TournamentMatch[]    @relation("BracketAdvance")
  scores          TournamentSetScore[]

  @@index([poolId])
  @@index([bracketId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([nextMatchId])
  @@index([refTeamId])
  @@index([status])
}

model TournamentSetScore {
  id        String          @id @default(cuid())
  matchId   String
  match     TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber Int
  homeScore Int
  awayScore Int

  @@unique([matchId, setNumber])
}

// ─── REGISTRATION & CONTACT ───

model Registration {
  id            String   @id @default(cuid())
  type          String
  leagueSlug    String?
  tournamentId  String?
  teamName      String?
  captainName   String
  captainEmail  String
  captainPhone  String?
  playerCount   Int?
  playerNames   String?
  skillLevel    String?
  preferredDay  String?
  paymentStatus String   @default("pending")
  notes         String?
  heardAboutUs  String?
  createdAt     DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Waiver {
  id               String   @id @default(cuid())
  fullName         String
  email            String
  phone            String?
  dateOfBirth      String?
  emergencyName    String?
  emergencyPhone   String?
  leagueDay        String?
  tournamentName   String?
  teamName         String?
  agreedToTerms    Boolean  @default(false)
  agreedToLiability Boolean @default(false)
  agreedToMedia    Boolean  @default(false)
  signatureName    String
  signedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
}
