generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tournament {
  id            String   @id @default("current")
  teams         Json
  scores        Json
  playoffScores Json     @default("{}")
  started       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}